{
    "hooks": {
        "SessionStart": [
            {
                "matcher": "*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "npx -y @dotcontext/cli@latest hook dispatch --source codex"
                    }
                ]
            },
            {
                "matcher": "startup|resume",
                "hooks": [
                    {
                        "type": "command",
                        "command": "/home/aicoders/workspace/harness-loop/.codex/log-hook.sh SessionStart"
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": "^Write$|^Edit$|^Bash$",
                "hooks": [
                    {
                        "type": "command",
                        "command": "npx -y @dotcontext/cli@latest hook dispatch --source codex"
                    }
                ]
            },
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "/home/aicoders/workspace/harness-loop/.codex/log-hook.sh PostToolUse"
                    }
                ]
            }
        ],
        "Stop": [
            {
                "matcher": "*",
                "hooks": [
                    {
                        "type": "command",
                        "command": "npx -y @dotcontext/cli@latest hook dispatch --source codex"
                    }
                ]
            },
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "/home/aicoders/workspace/harness-loop/.codex/log-hook.sh Stop",
                        "timeout": 30
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "/home/aicoders/workspace/harness-loop/.codex/log-hook.sh PreToolUse"
                    }
                ]
            }
        ],
        "PermissionRequest": [
            {
                "matcher": "Bash",
                "hooks": [
                    {
                        "type": "command",
                        "command": "/home/aicoders/workspace/harness-loop/.codex/log-hook.sh PermissionRequest"
                    }
                ]
            }
        ],
        "UserPromptSubmit": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "/home/aicoders/workspace/harness-loop/.codex/log-hook.sh UserPromptSubmit"
                    }
                ]
            }
        ]
    }
}